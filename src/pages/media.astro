---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import PressPhotosGallery from "../components/media/PressPhotosGallery.astro";
import LivePhotoGrid from "../components/media/LivePhotoGrid.astro";
import VideoGallery from "../components/media/VideoGallery.astro";
import VideoLightbox from "../components/media/VideoLightbox";
import { getEntry } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("pageContent", "page-content");
const pc = pcEntry!.data.media;
---

<Base
  title="Media — Giorgio Lorefice"
  description="Press photos, live performance images, music videos, and aftermovies for Giorgio Lorefice — underground techno DJ."
>
  <Header />
  <main>
    <PageHeader
      number="[ 004 / media ]"
      name="media"
      titleLine1={t(pc.titleLine1, locale)}
      titleLine2={t(pc.titleLine2, locale)}
    />
    <PressPhotosGallery />
    <LivePhotoGrid />
    <VideoGallery />
  </main>
  <Footer />
  <VideoLightbox client:idle />
</Base>
