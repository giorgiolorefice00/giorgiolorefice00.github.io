---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import PageHeader from "../components/PageHeader.astro";
import Footer from "../components/Footer.astro";
import PressPhotosGallery from "../components/media/PressPhotosGallery.astro";
import LivePhotoGrid from "../components/media/LivePhotoGrid.astro";
import VideoGallery from "../components/media/VideoGallery.astro";
import VideoLightbox from "../components/VideoLightbox";
---

<Base title="Media — Giorgio Lorefice">
  <Header />
  <main>
    <PageHeader
      number="[ 004 / media ]"
      name="media"
      titleLine1="THE VISUAL"
      titleLine2="RECORD."
    />
    <PressPhotosGallery />
    <LivePhotoGrid />
    <VideoGallery />
  </main>
  <Footer />
  <VideoLightbox client:load />
</Base>
