---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import SkullScene from "../components/contact/SkullScene";
import { getEntry } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("contactText", "contact-text");
const pc = pcEntry!.data;
const siteEntry = await getEntry("siteConfig", "site-config");
const contacts = siteEntry!.data.contacts;
---

<Base
  title="Contact — Giorgio Lorefice"
  description="Get in touch with Giorgio Lorefice. Direct email and phone contact."
>
  <Header />
  <main>
    <PageHeader
      number="[ 005 / contact ]"
      name="contact"
      titleLine1={t(pc.titleLine1, locale)}
      titleLine2={t(pc.titleLine2, locale)}
    />

    <section class="contact-section">
      <!-- Three.js skull background -->
      <div style="position:absolute;inset:0;z-index:0;pointer-events:none;">
        <SkullScene client:visible />
      </div>
      <!-- Subtle overlay — shader bg is already mostly black, just soften harsh edges -->
      <div style="position:absolute;inset:0;background:rgba(0,0,0,0.3);z-index:1;pointer-events:none;" aria-hidden="true"></div>

      <!-- Contact content -->
      <div class="contact-inner" style="position:relative;z-index:2;text-align:center;">

        <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:24px;display:flex;align-items:center;justify-content:center;gap:12px;">
          <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
          {t(pc.contactEyebrow, locale)}
          <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
        </div>

        {pc.contactIntroLine && (
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b6b6b;letter-spacing:0.1em;margin-bottom:48px;">
            {t(pc.contactIntroLine, locale)}
          </p>
        )}

        <!-- EMAIL -->
        <div style="margin-bottom:40px;">
          {pc.emailLabel && (
            <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:10px;">
              {t(pc.emailLabel, locale)}
            </div>
          )}
          <a
            href={`mailto:${contacts.email}`}
            style="font-family:'Anton',sans-serif;font-size:clamp(24px,3.5vw,52px);color:#c8102e;letter-spacing:0.02em;text-decoration:none;line-height:1;transition:color 0.15s;display:block;"
            onmouseover="this.style.color='#ff1f1f'"
            onmouseout="this.style.color='#c8102e'"
          >
            {contacts.email}
          </a>
        </div>

        <!-- PHONE -->
        {contacts.phone && (
          <div style="margin-bottom:48px;">
            {pc.phoneLabel && (
              <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:10px;">
                {t(pc.phoneLabel, locale)}
              </div>
            )}
            <a
              href={`tel:${contacts.phone.replace(/\s/g, "")}`}
              style="font-family:'Anton',sans-serif;font-size:clamp(24px,3.5vw,52px);color:#e8e8e8;letter-spacing:0.02em;text-decoration:none;line-height:1;transition:color 0.15s;display:block;"
              onmouseover="this.style.color='#c8102e'"
              onmouseout="this.style.color='#e8e8e8'"
            >
              {contacts.phone}
            </a>
          </div>
        )}

        {pc.contactNote && (
          <p style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.14em;">
            {t(pc.contactNote, locale)}
          </p>
        )}

      </div>

      <!-- Attribution — CC BY-NC 4.0 required -->
      <p style="position:absolute;bottom:12px;right:16px;z-index:3;font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(107,107,107,0.5);letter-spacing:0.12em;pointer-events:none;">
        shader by KΛTUR · CC BY-NC 4.0
      </p>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .contact-section {
    /* Fallback: dark blood-red radial glow when WebGL/shader can't run */
    background:
      radial-gradient(ellipse at 50% 45%, rgba(200,16,46,0.18) 0%, rgba(0,0,0,1) 68%),
      #000;
    position: relative;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 72px;
  }
  .contact-inner {
    max-width: 640px;
    width: 100%;
  }
  @media (max-width: 768px) {
    .contact-section { padding: 80px 24px; }
  }
</style>
