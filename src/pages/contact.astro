---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import SkullScene from "../components/contact/SkullScene";
import BookingForm from "../components/contact/BookingForm";
import DirectContact from "../components/contact/DirectContact.astro";
import GeneralInquiry from "../components/contact/GeneralInquiry.astro";
import { getEntry } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("pageContent", "page-content");
const pc = pcEntry!.data.contact;
---

<Base
  title="Booking — Giorgio Lorefice"
  description="Book Giorgio Lorefice for club nights, festivals, and live sets. Booking inquiries, management contacts, and press information."
>
  <Header />
  <main>
    <PageHeader
      number="[ 005 / contact ]"
      name="contact"
      titleLine1={t(pc.titleLine1, locale)}
      titleLine2={t(pc.titleLine2, locale)}
    />

    <!-- BOOKING FORM SECTION — skull behind, form in front -->
    <section style="background:#000;padding:100px 72px;position:relative;overflow:hidden;min-height:900px;">
      <div style="position:absolute;inset:0;z-index:0;">
        <SkullScene client:load />
      </div>
      <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,0.97) 40%,rgba(0,0,0,0.6) 100%);z-index:1;pointer-events:none;"></div>
      <div style="position:relative;z-index:2;">
        <BookingForm client:idle />
      </div>
    </section>

    <DirectContact />
    <GeneralInquiry />
  </main>
  <Footer />
</Base>
