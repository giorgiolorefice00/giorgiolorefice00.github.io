---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import { SmokeBackground } from "../components/home/SmokeBackground";
import FireTrailFrame from "../components/contact/FireTrailFrame";
import { getEntry } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("contactText", "contact-text");
const pc = pcEntry!.data;
const siteEntry = await getEntry("siteConfig", "site-config");
const contacts = siteEntry!.data.contacts;
---

<Base
  title="Contact — Giorgio Lorefice"
  description="Get in touch with Giorgio Lorefice. Direct email and phone contact."
>
  <Header />
  <main>
    <PageHeader
      number="[ 005 / contact ]"
      name="contact"
      titleLine1={t(pc.titleLine1, locale)}
      titleLine2={t(pc.titleLine2, locale)}
    />

    <section class="contact-section">
      <!-- Smoke background — dimmed to 40% opacity for calm atmosphere -->
      <div class="contact-smoke" aria-hidden="true">
        <SmokeBackground client:visible smokeColor="#C8102E" />
      </div>
      <!-- Dark overlay for text contrast -->
      <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);z-index:1;pointer-events:none;" aria-hidden="true"></div>

      <!-- Contact content -->
      <div class="contact-inner" style="position:relative;z-index:2;text-align:center;">

        <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:24px;display:flex;align-items:center;justify-content:center;gap:12px;">
          <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
          {t(pc.contactEyebrow, locale)}
          <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
        </div>

        {pc.contactIntroLine && (
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b6b6b;letter-spacing:0.1em;margin-bottom:48px;">
            {t(pc.contactIntroLine, locale)}
          </p>
        )}

        <!-- EMAIL — card with animated fire-trail border -->
        <div class="email-card-wrapper">
          <FireTrailFrame client:visible />
          <div class="email-card-content">
            {pc.emailLabel && (
              <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:10px;">
                {t(pc.emailLabel, locale)}
              </div>
            )}
            <a
              href={`mailto:${contacts.email}`}
              style="font-family:'Anton',sans-serif;font-size:clamp(18px,2.8vw,42px);color:#c8102e;letter-spacing:0.02em;text-decoration:none;line-height:1;transition:color 0.15s;display:block;word-break:break-all;"
              onmouseover="this.style.color='#ff1f1f'"
              onmouseout="this.style.color='#c8102e'"
            >
              {contacts.email}
            </a>
          </div>
        </div>

        <!-- PHONE — plain styled text, no shader -->
        {contacts.phone && (
          <div style="margin-top:40px;margin-bottom:48px;">
            {pc.phoneLabel && (
              <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:10px;">
                {t(pc.phoneLabel, locale)}
              </div>
            )}
            <a
              href={`tel:${contacts.phone.replace(/\s/g, "")}`}
              style="font-family:'Anton',sans-serif;font-size:clamp(22px,3vw,48px);color:#e8e8e8;letter-spacing:0.02em;text-decoration:none;line-height:1;transition:color 0.15s;display:block;"
              onmouseover="this.style.color='#c8102e'"
              onmouseout="this.style.color='#e8e8e8'"
            >
              {contacts.phone}
            </a>
          </div>
        )}

        {pc.contactNote && (
          <p style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.14em;">
            {t(pc.contactNote, locale)}
          </p>
        )}

      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .contact-section {
    /* Fallback background when shaders can't run */
    background:
      radial-gradient(ellipse at 50% 45%, rgba(200,16,46,0.15) 0%, rgba(0,0,0,1) 65%),
      #000;
    position: relative;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 72px;
  }

  /* Smoke layer: absolute fill, dimmed */
  .contact-smoke {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.45;
  }

  .contact-inner {
    max-width: 700px;
    width: 100%;
  }

  /* Email card wrapper — canvas renders the fire trail behind the content */
  .email-card-wrapper {
    position: relative;
    width: 100%;
    max-width: 640px;
    margin: 0 auto 0;
    /* Aspect ratio drives canvas dimensions */
    aspect-ratio: 3 / 1;
    /* Static border fallback (hidden when canvas is active via :has) */
    border: 1px solid #c8102e;
    border-radius: 2px;
    background: rgba(0, 0, 0, 0.35);
  }

  /* Hide static border when the fire-trail canvas is present */
  .email-card-wrapper:has(canvas) {
    border: none;
    background: transparent;
  }

  .email-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px 32px;
  }

  @media (max-width: 768px) {
    .contact-section { padding: 80px 24px; }
    .email-card-wrapper { aspect-ratio: 5 / 2; }
  }

  @media (max-width: 480px) {
    .email-card-wrapper { aspect-ratio: 2 / 1; }
  }
</style>
