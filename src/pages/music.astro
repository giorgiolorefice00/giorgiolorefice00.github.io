---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import FeaturedRelease from "../components/music/FeaturedRelease.astro";
import StreamingEmbeds from "../components/music/StreamingEmbeds.astro";
import MixesLibrary from "../components/music/MixesLibrary.astro";
import Albums from "../components/music/Albums.astro";
import { getEntry } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const mtEntry = await getEntry("musicText", "music-page");
const mt = mtEntry!.data;
const pcEntry = await getEntry("pageContent", "page-content");
const pc = pcEntry!.data;
---

<Base
  title="Music — Giorgio Lorefice"
  description="Releases, mixes, and full albums catalogue for Giorgio Lorefice. Industrial techno and acid released on Mord, Soma, Truncate Records, and Blueprint."
>
  <Header />
  <main>
    <PageHeader
      number="[ 002 / music ]"
      name="music"
      titleLine1={t(pc.music.titleLine1, locale)}
      titleLine2={t(pc.music.titleLine2, locale)}
    />
    <FeaturedRelease />
    <StreamingEmbeds />
    <MixesLibrary />
    <Albums />
  </main>
  <Footer />
</Base>
