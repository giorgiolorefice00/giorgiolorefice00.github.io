import StreamingEmbeds from "../components/music/StreamingEmbeds.astro";
import MixesLibrary from "../components/music/MixesLibrary.astro";
import Discography from "../components/music/Discography.astro";
---

<Base title="Music — Giorgio Lorefice">
  <Header />
  <main>
    <PageHeader
      number="[ 002 / music ]"
      name="music"
      titleLine1="THE SOUND"
      titleLine2="ON RECORD."
    />
