---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import FeaturedRelease from "../components/music/FeaturedRelease.astro";
import StreamingEmbeds from "../components/music/StreamingEmbeds.astro";
import MixesLibrary from "../components/music/MixesLibrary.astro";
import Discography from "../components/music/Discography.astro";
---

<Base
  title="Music — Giorgio Lorefice"
  description="Releases, mixes, and full discography for Giorgio Lorefice. Industrial techno and acid released on Mord, Soma, Truncate Records, and Blueprint."
>
  <Header />
  <main>
    <PageHeader
      number="[ 002 / music ]"
      name="music"
      titleLine1="THE SOUND"
      titleLine2="ON RECORD."
    />
    <FeaturedRelease />
    <StreamingEmbeds />
    <MixesLibrary />
    <Discography />
  </main>
  <Footer />
</Base>
