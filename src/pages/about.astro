---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import BiographyBlock from "../components/about/BiographyBlock.astro";
import AchievementsResidencies from "../components/about/AchievementsResidencies.astro";
import PartnershipsMarquee from "../components/about/PartnershipsMarquee.astro";
import PressArticlesGrid from "../components/about/PressArticlesGrid.astro";
import EpkDownloadBand from "../components/about/EpkDownloadBand.astro";
import { getEntry } from "astro:content";

const about = await getEntry("about", "about");
const { fullBio, factFile } = about!.data;
---

<Base title="About — Giorgio Lorefice">
  <Header />
  <main>
    <PageHeader
      number="[ 001 / about ]"
      name="about"
      titleLine1="THE MAN"
      titleLine2="BEHIND THE DECKS."
    />
    <BiographyBlock fullBio={fullBio ?? []} factFile={factFile ?? []} />
    <AchievementsResidencies />
    <PartnershipsMarquee />
    <PressArticlesGrid />
    <EpkDownloadBand />
  </main>
  <Footer />
</Base>
