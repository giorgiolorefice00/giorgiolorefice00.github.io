---
import Base from "../../layouts/Base.astro";
import Header from "../../components/layout/Header.astro";
import PageHeader from "../../components/layout/PageHeader.astro";
import Footer from "../../components/layout/Footer.astro";
import TourList from "../../components/events/TourList.astro";
import TourMap from "../../components/events/TourMap";
import PastArchive from "../../components/events/PastArchive.astro";
import { useTranslations } from "../../i18n";

const t = useTranslations("it");
---

<Base
  title="Date del Tour — Giorgio Lorefice"
  description="Date dei tour e performance passate di Giorgio Lorefice. Berghain, Fabric, Rex Club, Awakenings, Dekmantel e altro."
>
  <Header />
  <main>
    <PageHeader
      number={t.eyebrows.events}
      name={t.nav.events}
      titleLine1={t.pageHeaders.events.line1}
      titleLine2={t.pageHeaders.events.line2}
    />
    <TourList />
    <TourMap client:visible />
    <PastArchive />
  </main>
  <Footer />
</Base>
