---
import Base from "../../layouts/Base.astro";
import Header from "../../components/layout/Header.astro";
import PageHeader from "../../components/layout/PageHeader.astro";
import Footer from "../../components/layout/Footer.astro";
import PressPhotosGallery from "../../components/media/PressPhotosGallery.astro";
import LivePhotoGrid from "../../components/media/LivePhotoGrid.astro";
import VideoGallery from "../../components/media/VideoGallery.astro";
import VideoLightbox from "../../components/media/VideoLightbox";
import { useTranslations } from "../../i18n";

const t = useTranslations("it");
---

<Base
  title="Media — Giorgio Lorefice"
  description="Foto stampa, immagini live, videoclip e aftermovie di Giorgio Lorefice — DJ techno underground."
>
  <Header />
  <main>
    <PageHeader
      number={t.eyebrows.press}
      name={t.nav.media}
      titleLine1={t.pageHeaders.media.line1}
      titleLine2={t.pageHeaders.media.line2}
    />
    <PressPhotosGallery />
    <LivePhotoGrid />
    <VideoGallery />
  </main>
  <Footer />
  <VideoLightbox client:idle />
</Base>
