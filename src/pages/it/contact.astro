---
import Base from "../../layouts/Base.astro";
import Header from "../../components/layout/Header.astro";
import PageHeader from "../../components/layout/PageHeader.astro";
import Footer from "../../components/layout/Footer.astro";
import SkullScene from "../../components/contact/SkullScene";
import BookingForm from "../../components/contact/BookingForm";
import DirectContact from "../../components/contact/DirectContact.astro";
import GeneralInquiry from "../../components/contact/GeneralInquiry.astro";
import { useTranslations } from "../../i18n";

const t = useTranslations("it");
---

<Base
  title="Booking — Giorgio Lorefice"
  description="Prenota Giorgio Lorefice per serate in club, festival e live set. Richieste di booking, management e ufficio stampa."
>
  <Header />
  <main>
    <PageHeader
      number="[ 005 / contatti ]"
      name={t.nav.contact}
      titleLine1={t.pageHeaders.contact.line1}
      titleLine2={t.pageHeaders.contact.line2}
    />

    <section style="background:#000;padding:100px 72px;position:relative;overflow:hidden;min-height:900px;">
      <div style="position:absolute;inset:0;z-index:0;">
        <SkullScene client:visible />
      </div>
      <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,0.97) 40%,rgba(0,0,0,0.6) 100%);z-index:1;pointer-events:none;"></div>
      <div style="position:relative;z-index:2;">
        <BookingForm client:idle />
      </div>
    </section>

    <DirectContact />
    <GeneralInquiry />
  </main>
  <Footer />
</Base>
