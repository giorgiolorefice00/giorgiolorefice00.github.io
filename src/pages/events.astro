---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import TourList from "../components/events/TourList.astro";
import TourMap from "../components/events/TourMap.astro";
import PastArchive from "../components/events/PastArchive.astro";
import { getEntry, getCollection } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("eventsText", "events-text");
const pc = pcEntry!.data;

// Build Event JSON-LD for all upcoming events
const MONTH: Record<string, string> = {
  JAN:"01",FEB:"02",MAR:"03",APR:"04",MAY:"05",JUN:"06",
  JUL:"07",AUG:"08",SEP:"09",OCT:"10",NOV:"11",DEC:"12",
};
const allEvents = await getCollection("events");
const upcomingEvents = allEvents.filter((ev) => !ev.data.isPast);
const eventSchema = {
  "@context": "https://schema.org",
  "@graph": upcomingEvents.map((ev) => {
    const mm = MONTH[ev.data.month.toUpperCase()] ?? "01";
    const dd = ev.data.day.padStart(2, "0");
    const startTime = ev.data.setTime.split(/[–\-]/)[0]?.trim() ?? "00:00";
    return {
      "@type": "Event",
      "name": `${ev.data.venue} — ${ev.data.eventTitle.en}`,
      "startDate": `${ev.data.year}-${mm}-${dd}T${startTime}:00`,
      "eventStatus": ev.data.status === "sold-out"
        ? "https://schema.org/EventSoldOut"
        : "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": ev.data.venue,
        "address": { "@type": "PostalAddress", "addressLocality": ev.data.city },
      },
      "performer": { "@type": "MusicGroup", "name": "Giorgio Lorefice" },
      "organizer": {
        "@type": "MusicGroup",
        "name": "Giorgio Lorefice",
        "url": "https://giorgiolorefice.com",
      },
    };
  }),
};
---

<Base
  title="Tour Dates — Giorgio Lorefice"
  description="Upcoming tour dates and past performances for Giorgio Lorefice. Berghain, Fabric, Rex Club, Awakenings, Dekmantel, and more."
  jsonLd={eventSchema}
>
  <Header />
  <main>
    <PageHeader
      number="[ 003 / events ]"
      name="events"
      titleLine1={t(pc.titleLine1, locale)}
      titleLine2={t(pc.titleLine2, locale)}
    />
    <TourList />
    <TourMap />
    <PastArchive />
  </main>
  <Footer />
</Base>
