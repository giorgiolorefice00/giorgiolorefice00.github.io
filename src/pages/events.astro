---
import Base from "../layouts/Base.astro";
import Header from "../components/layout/Header.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import Footer from "../components/layout/Footer.astro";
import TourList from "../components/events/TourList.astro";
import TourMap from "../components/events/TourMap";
import PastArchive from "../components/events/PastArchive.astro";
import { getEntry } from "astro:content";
import { t, type Locale } from "../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("pageContent", "page-content");
const pc = pcEntry!.data.events;
---

<Base
  title="Tour Dates — Giorgio Lorefice"
  description="Upcoming tour dates and past performances for Giorgio Lorefice. Berghain, Fabric, Rex Club, Awakenings, Dekmantel, and more."
>
  <Header />
  <main>
    <PageHeader
      number="[ 003 / events ]"
      name="events"
      titleLine1={t(pc.titleLine1, locale)}
      titleLine2={t(pc.titleLine2, locale)}
    />
    <TourList />
    <TourMap client:visible />
    <PastArchive />
  </main>
  <Footer />
</Base>
