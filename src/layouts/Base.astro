---
import "../styles/global.css";
import "../styles/responsive.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Giorgio Lorefice — Underground Techno DJ",
  description = "Milano-based underground rave DJ. Industrial techno, acid, warehouse architecture.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/logo.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=JetBrains+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Reusable SVG filters — referenced by id throughout the page -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="0"
      height="0"
      aria-hidden="true"
      style="position:absolute;overflow:hidden;"
    >
      <defs>
        <!--
          Duotone: shadows → #000000, highlights → #C8102E (blood red).
          feColorMatrix desaturates; feComponentTransfer maps 0→black, 1→#C8102E.
        -->
        <filter id="duotone" color-interpolation-filters="sRGB">
          <feColorMatrix type="saturate" values="0" result="gray" />
          <feComponentTransfer>
            <feFuncR type="table" tableValues="0 0.784" />
            <feFuncG type="table" tableValues="0 0.063" />
            <feFuncB type="table" tableValues="0 0.180" />
          </feComponentTransfer>
        </filter>
      </defs>
    </svg>

    <div class="scanlines"></div>
    <div class="grain"></div>
    <slot />
  </body>
</html>
