---
import "../styles/global.css";
import "../styles/responsive.css";
import SEOHead from "../components/layout/SEOHead.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "profile" | "music.album";
  noindex?: boolean;
  jsonLd?: object;
}

const { title, description, image, type, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=JetBrains+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="0"
      height="0"
      aria-hidden="true"
      style="position:absolute;overflow:hidden;"
    >
      <defs>
        <filter id="duotone" color-interpolation-filters="sRGB">
          <feColorMatrix type="saturate" values="0" result="gray" />
          <feComponentTransfer>
            <feFuncR type="table" tableValues="0 0.784" />
            <feFuncG type="table" tableValues="0 0.063" />
            <feFuncB type="table" tableValues="0 0.180" />
          </feComponentTransfer>
        </filter>
      </defs>
    </svg>

    <div class="scanlines"></div>
    <div class="grain"></div>
    <slot />
  </body>
</html>
