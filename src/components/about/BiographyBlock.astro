---
import { Image } from "astro:assets";
import djPhoto from "../../assets/dj-photo.jpg";

interface Props {
  fullBio: string[];
  factFile: { label: string; value: string }[];
}
const { fullBio, factFile } = Astro.props;
const pullQuotes = [
  "the room you walked into was not the room you'd walk out of.",
  "scarcity is part of the art.",
];
---

<section style="background:#000;padding:100px 72px;">
  <div class="bio-cols" style="display:flex;gap:80px;align-items:flex-start;">

    <!-- LEFT 58% — long-form bio -->
    <div style="flex:0 0 58%;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:32px;display:flex;align-items:center;gap:12px;">
        <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
        A — biography
      </div>

      <!-- PARAGRAPH 1 with drop cap -->
      <div style="margin-bottom:24px;line-height:1.9;">
        <span style="float:left;font-family:'Anton',sans-serif;font-size:96px;color:#c8102e;line-height:0.75;margin-right:12px;margin-top:8px;">G</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#9a9a9a;letter-spacing:0.04em;">
          {fullBio[0]?.slice(1)}
        </span>
      </div>

      <!-- PARAGRAPH 2 -->
      <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#9a9a9a;letter-spacing:0.04em;line-height:1.9;margin-bottom:28px;">
        {fullBio[1]}
      </p>

      <!-- PULL QUOTE 1 -->
      <blockquote style="border-left:4px solid #c8102e;padding:12px 24px;margin:0 0 28px;font-family:'Anton',sans-serif;font-size:clamp(18px,2vw,24px);color:#e8e8e8;letter-spacing:0.02em;line-height:1.3;">
        "{pullQuotes[0]}"
      </blockquote>

      <!-- PARAGRAPHS 3 & 4 -->
      {fullBio.slice(2, 4).map((p) => (
        <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#9a9a9a;letter-spacing:0.04em;line-height:1.9;margin-bottom:28px;">{p}</p>
      ))}

      <!-- PULL QUOTE 2 -->
      <blockquote style="border-left:4px solid #c8102e;padding:12px 24px;margin:0 0 28px;font-family:'Anton',sans-serif;font-size:clamp(18px,2vw,24px);color:#e8e8e8;letter-spacing:0.02em;line-height:1.3;">
        "{pullQuotes[1]}"
      </blockquote>

      <!-- PARAGRAPH 5 -->
      {fullBio[4] && (
        <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#9a9a9a;letter-spacing:0.04em;line-height:1.9;margin-bottom:40px;">{fullBio[4]}</p>
      )}

      <a href="#" style="display:inline-flex;align-items:center;gap:8px;color:#6b6b6b;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.14em;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='#c8102e'" onmouseout="this.style.color='#6b6b6b'">
        ↓ download full bio (.txt)
      </a>
    </div>

    <!-- RIGHT 42% — sticky portrait + fact file -->
    <div class="bio-right" style="flex:1 1 0;position:sticky;top:96px;">
      <!-- PORTRAIT -->
      <div style="position:relative;width:100%;aspect-ratio:3/4;overflow:hidden;margin-bottom:0;">
        <div class="photo-duotone" style="position:absolute;inset:0;">
          <Image src={djPhoto} width={600} height={800} alt="Giorgio Lorefice" style="width:100%;height:100%;object-fit:cover;object-position:30% 15%;" loading="lazy" />
        </div>
        <div style="position:absolute;top:0;left:0;width:3px;height:100%;background:#c8102e;z-index:5;"></div>
      </div>

      <!-- FACT FILE -->
      <div style="border:1px solid #1a1a1a;padding:24px;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.22em;margin-bottom:20px;">[ FACT FILE ]</div>
        {factFile.map((row, i) => (
          <div style={`display:flex;justify-content:space-between;align-items:baseline;padding:10px 0;${i < factFile.length - 1 ? 'border-bottom:1px solid #111;' : ''}`}>
            <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.14em;">{row.label}</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#e8e8e8;letter-spacing:0.08em;text-align:right;max-width:60%;">{row.value}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
