---
import { getCollection } from "astro:content";

const partnerships = await getCollection("partnerships");
const names = partnerships.map((p) => p.data.name);
// duplicate for seamless loop
const doubled = [...names, ...names];
---

<section style="background:#000;padding:80px 0;border-top:1px solid #c8102e;overflow:hidden;">
  <div style="padding:0 72px;margin-bottom:48px;">
    <div style="line-height:0.92;">
      <div style="font-family:'Anton',sans-serif;font-size:clamp(36px,4vw,56px);color:#e8e8e8;letter-spacing:0.01em;opacity:0.2;">STAGES. BRANDS.</div>
      <div style="font-family:'Anton',sans-serif;font-size:clamp(36px,4vw,56px);color:#c8102e;letter-spacing:0.01em;opacity:0.2;">RITUALS.</div>
    </div>
  </div>

  <div class="marquee-outer">
    <div class="marquee-track">
      {doubled.map((name, i) => (
        <span style="font-family:'Anton',sans-serif;font-size:clamp(28px,3.5vw,48px);color:#e8e8e8;letter-spacing:0.06em;padding:0 48px;white-space:nowrap;opacity:0.18;">
          {name}
          <span style="color:#c8102e;margin-left:48px;opacity:0.5;">·</span>
        </span>
      ))}
    </div>
  </div>
</section>
