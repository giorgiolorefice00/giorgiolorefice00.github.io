---
import { getCollection } from "astro:content";

const press = (await getCollection("press")).sort((a, b) => a.id.localeCompare(b.id));
---

<section style="background:#0a0a0a;padding:100px 72px;">
  <div style="margin-bottom:56px;">
    <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
      <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
      D — press
    </div>
    <div style="line-height:0.92;">
      <div style="font-family:'Anton',sans-serif;font-size:clamp(40px,4.5vw,72px);color:#e8e8e8;letter-spacing:0.01em;">WHAT THEY</div>
      <div style="font-family:'Anton',sans-serif;font-size:clamp(40px,4.5vw,72px);color:#c8102e;letter-spacing:0.01em;">WROTE.</div>
    </div>
  </div>

  <div class="press-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    {press.map((p) => (
      <div class="press-card-about">
        <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.22em;">{p.data.publication}</div>
        <p style="font-family:'Anton',sans-serif;font-size:clamp(16px,1.6vw,22px);color:#e8e8e8;line-height:1.3;letter-spacing:0.01em;flex:1;">
          "{p.body!.trim()}"
        </p>
        <div style="display:flex;align-items:center;gap:12px;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#e8e8e8;letter-spacing:0.1em;">{p.data.author}</span>
          <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.1em;">{p.data.date}</span>
        </div>
      </div>
    ))}
  </div>
</section>
