---
import { getCollection } from "astro:content";

const videos = (await getCollection("videos")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);

const tabs = ["music videos", "live sets", "aftermovies", "interviews"];

const catToTab: Record<string, string> = {
  "music-video": "music videos",
  "live-set": "live sets",
  "aftermovie": "aftermovies",
  "interview": "interviews",
};
---

<section style="background:#000;padding:100px 72px;border-top:1px solid #c8102e;">
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:48px;display:flex;align-items:center;gap:12px;">
    <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
    C — video
  </div>

  <div style="line-height:0.92;margin-bottom:48px;">
    <div style="font-family:'Anton',sans-serif;font-size:clamp(56px,7vw,112px);color:#e8e8e8;letter-spacing:0.01em;">VIDEO.</div>
  </div>

  <!-- TAB BAR -->
  <div id="video-tabs" style="display:flex;gap:32px;border-bottom:1px solid #1a1a1a;margin-bottom:40px;">
    {tabs.map((tab, i) => (
      <button
        class={`video-tab${i === 0 ? " active" : ""}`}
        data-tab={tab}
        style={`font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.14em;color:${i === 0 ? '#c8102e' : '#6b6b6b'};background:none;border:none;border-bottom:${i === 0 ? '1px solid #c8102e' : '1px solid transparent'};padding:0 0 14px;cursor:pointer;transition:color 0.15s;margin-bottom:-1px;`}
        onclick="
          document.querySelectorAll('.video-tab').forEach(b => {
            b.style.color = '#6b6b6b';
            b.style.borderBottom = '1px solid transparent';
          });
          this.style.color = '#c8102e';
          this.style.borderBottom = '1px solid #c8102e';
          const t = this.dataset.tab;
          document.querySelectorAll('.video-card').forEach(c => {
            c.style.display = (c.dataset.tab === t) ? '' : 'none';
          });
        "
      >{tab}</button>
    ))}
  </div>

  <!-- VIDEO GRID -->
  <div class="video-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    {videos.map((v, i) => {
      const tab = catToTab[v.data.category] ?? "music videos";
      const isFirst = tab === "music videos";
      return (
        <div
          class="video-card"
          data-tab={tab}
          data-video-id={v.data.youtubeId ?? v.data.vimeoId ?? ""}
          data-title={v.data.title}
          style={`${!isFirst ? 'display:none;' : ''}border:1px solid #1a1a1a;overflow:hidden;cursor:pointer;transition:border-color 0.2s;`}
          onmouseover="this.style.borderColor='#c8102e'" onmouseout="this.style.borderColor='#1a1a1a'"
          onclick={`document.dispatchEvent(new CustomEvent('openLightbox', {detail:{youtubeId:'${v.data.youtubeId ?? ""}',vimeoId:'${v.data.vimeoId ?? ""}',title:'${v.data.title.replace(/'/g, "\\'")}'}}))`}
        >
          <!-- THUMBNAIL PLACEHOLDER -->
          <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#0a0002 0%,#050000 50%,#1a0008 100%);position:relative;display:flex;align-items:center;justify-content:center;">
            <!-- PLAY BUTTON -->
            <div style="width:48px;height:48px;background:#c8102e;display:flex;align-items:center;justify-content:center;transition:background 0.15s;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#000"><path d="M8 5v14l11-7z"/></svg>
            </div>
            <!-- DURATION -->
            <div style="position:absolute;bottom:8px;right:10px;font-family:'JetBrains Mono',monospace;font-size:9px;color:#e8e8e8;letter-spacing:0.1em;background:rgba(0,0,0,0.8);padding:2px 6px;">{v.data.duration}</div>
          </div>
          <!-- META -->
          <div style="padding:16px;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#e8e8e8;letter-spacing:0.06em;margin-bottom:6px;line-height:1.4;">{v.data.title}</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.1em;">{v.data.meta}</div>
          </div>
        </div>
      );
    })}
  </div>
</section>
