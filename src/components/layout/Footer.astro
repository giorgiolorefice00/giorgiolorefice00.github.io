---
import { Image } from "astro:assets";
import logoImg from "../../assets/logo.png";
import { getEntry } from "astro:content";
import { t, type Locale } from "../../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const ftEntry = await getEntry("footerText", "footer-text");
const ft = ftEntry!.data;
const htEntry = await getEntry("headerText", "header-text");
const nav = htEntry!.data.nav;

const siteEntry = await getEntry("siteConfig", "site-config");
const site = siteEntry!.data;

const base = import.meta.env.BASE_URL;
const navLinks = ["home", "about", "music", "events", "media", "contact"] as const;

// Only include external links when a URL is actually configured
const listenLinks = [
  site.socials.spotify      && { label: "spotify",       href: site.socials.spotify },
  site.socials.soundcloud   && { label: "soundcloud",    href: site.socials.soundcloud },
  site.socials.appleMusic   && { label: "apple music",   href: site.socials.appleMusic },
  site.socials.youtubeMusic && { label: "youtube music", href: site.socials.youtubeMusic },
].filter(Boolean) as { label: string; href: string }[];

const followLinks = [
  site.socials.instagram    && { label: "instagram",     href: site.socials.instagram },
  { label: "email", href: `mailto:${site.contacts.email}` },
].filter(Boolean) as { label: string; href: string }[];
---

<footer data-reveal="fade" style="background:#000;border-top:1px solid #c8102e;padding:64px 72px 0;">

  <!-- TOP ROW -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:64px;">
    <Image
      src={logoImg}
      width={160}
      height={160}
      alt=""
      aria-hidden="true"
      style="width:80px;height:80px;object-fit:cover;"
      loading="lazy"
    />
    <div style="font-family:'Anton',sans-serif;font-size:clamp(28px,3vw,48px);color:#c8102e;letter-spacing:0.04em;text-align:right;line-height:1.1;">
      {t(ft.brandPhrase1, locale)}<br />{t(ft.brandPhrase2, locale)}
    </div>
  </div>

  <!-- MIDDLE — 3 COLS -->
  <div class="footer-cols" style="display:flex;gap:80px;margin-bottom:48px;">

    <!-- SITEMAP -->
    <div style="flex:1;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.2em;margin-bottom:20px;text-transform:uppercase;">{t(ft.sitemap, locale)}</div>
      <div class="footer-link-col">
        {navLinks.map((k) => (
          <a href={k === "home" ? base : `${base}${k}`} class="footer-link">{t(nav[k], locale)}</a>
        ))}
      </div>
    </div>

    <!-- LISTEN -->
    <div style="flex:1;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.2em;margin-bottom:20px;text-transform:uppercase;">{t(ft.listen, locale)}</div>
      <div class="footer-link-col">
        {listenLinks.map((l) => (
          <a href={l.href} class="footer-link" target="_blank" rel="noopener">{l.label}</a>
        ))}
      </div>
    </div>

    <!-- FOLLOW -->
    <div style="flex:1;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.2em;margin-bottom:20px;text-transform:uppercase;">{t(ft.follow, locale)}</div>
      <div class="footer-link-col">
        {followLinks.map((l) => (
          <a href={l.href} class="footer-link" target={l.href.startsWith("mailto") ? undefined : "_blank"} rel={l.href.startsWith("mailto") ? undefined : "noopener"}>{l.label}</a>
        ))}
      </div>
    </div>

  </div>

  <!-- BOTTOM META -->
  <div style="border-top:1px solid #1a1a1a;padding:16px 0 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
    <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#767676;letter-spacing:0.06em;">
      © 2026 giorgio lorefice — {t(ft.rights, locale)}
    </span>
    <div style="display:flex;gap:24px;">
      {[
        { label: t(ft.privacy, locale),  href: "#" },
        { label: t(ft.terms, locale),    href: "#" },
        { label: t(ft.pressKit, locale), href: site.files.epk || "#" },
      ].map((l) => (
        <a
          href={l.href}
          style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#767676;text-decoration:none;letter-spacing:0.06em;transition:color 0.15s;"
          onmouseover="this.style.color='#e8e8e8'"
          onmouseout="this.style.color='#767676'"
        >{l.label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer-link-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #767676;
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: color 0.15s;
    display: block;
  }
  .footer-link:hover { color: #c8102e; }
</style>
