---
interface Props {
  number: string;   // e.g. "[ 001 / about ]"
  name: string;     // e.g. "about"
  titleLine1: string;
  titleLine2: string;
}

const { number, name, titleLine1, titleLine2 } = Astro.props;
---

<div class="page-header-band" style="background:#000;padding:140px 72px 56px;border-bottom:1px solid #c8102e;">

  <!-- BREADCRUMB -->
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#6b6b6b;letter-spacing:0.18em;margin-bottom:16px;">
    <span style="color:#c8102e;">home</span> / {name}
  </div>

  <!-- SECTION NUMBER -->
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
    <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
    {number}
  </div>

  <!-- TITLE -->
  <div style="line-height:0.92;">
    <div style="font-family:'Anton',sans-serif;font-size:clamp(56px,7vw,112px);color:#e8e8e8;letter-spacing:0.01em;">{titleLine1}</div>
    <div style="font-family:'Anton',sans-serif;font-size:clamp(56px,7vw,112px);color:#c8102e;letter-spacing:0.01em;">{titleLine2}</div>
  </div>

</div>
