---
interface Props {
  number: string;
  name: string;
  titleLine1: string;
  titleLine2: string;
}

const { number, name, titleLine1, titleLine2 } = Astro.props;
---

<div class="page-header-band" style="background:#000;padding:140px 72px 56px;border-bottom:1px solid #c8102e;">

  <!-- BREADCRUMB -->
  <nav aria-label="Breadcrumb" style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#6b6b6b;letter-spacing:0.18em;margin-bottom:16px;">
    <a href="/" style="color:#c8102e;text-decoration:none;">home</a> / {name}
  </nav>

  <!-- SECTION NUMBER -->
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:24px;display:flex;align-items:center;gap:12px;" aria-hidden="true">
    <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
    {number}
  </div>

  <!-- H1 PAGE TITLE — each inner page has exactly one h1 here -->
  <h1 style="margin:0;padding:0;line-height:0.92;font-size:clamp(56px,7vw,112px);font-family:'Anton',sans-serif;font-weight:400;letter-spacing:0.01em;">
    <span style="display:block;color:#e8e8e8;">{titleLine1}</span>
    <span style="display:block;color:#c8102e;">{titleLine2}</span>
  </h1>

</div>
