---
import { Image } from "astro:assets";
import logoImg from "../../assets/logo.png";

const navLinks = ["home", "about", "music", "events", "media", "contact"];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname;

const href = (link: string) => link === "home" ? `${base}/` : `${base}/${link}`;
const isActive = (link: string) => {
  if (link === "home") return path === base + "/" || path === base;
  return path.startsWith(base + "/" + link);
};
---

<!-- FIXED DESKTOP + MOBILE HEADER BAR -->
<header
  id="site-header"
  style="position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 48px;height:72px;background:transparent;border-bottom:1px solid transparent;transition:background 0.3s,border-color 0.3s;"
>
  <!-- LOGO -->
  <a href={`${base}/`} style="display:flex;align-items:center;flex-shrink:0;">
    <Image
      src={logoImg}
      width={104}
      height={104}
      alt="Giorgio Lorefice — home"
      style="width:52px;height:52px;object-fit:cover;"
      loading="eager"
    />
  </a>

  <!-- DESKTOP NAV (hidden via .header-nav on mobile) -->
  <nav class="header-nav" style="display:flex;gap:36px;align-items:center;">
    {navLinks.map((l) => (
      <a href={href(l)} class={`nav-link${isActive(l) ? " active" : ""}`}>{l}</a>
    ))}
  </nav>

  <!-- RIGHT SIDE -->
  <div style="display:flex;align-items:center;gap:16px;">
    <!-- SOCIAL ICONS (desktop only) -->
    <div class="header-socials" style="display:flex;gap:12px;align-items:center;">
      <button class="social-btn" title="Instagram" aria-label="Instagram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
          <rect x="2" y="2" width="20" height="20" rx="0"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </button>
      <button class="social-btn" title="SoundCloud" aria-label="SoundCloud">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M1.175 12.225c-.056 0-.094.037-.1.094l-.233 2.154.233 2.105c.006.06.044.094.1.094s.094-.037.1-.094l.255-2.105-.27-2.154c-.006-.057-.045-.094-.1-.094m1.655-.557c-.068 0-.116.05-.122.116l-.2 2.711.2 2.568c.006.067.054.117.122.117s.116-.05.122-.117l.227-2.568-.227-2.71c-.006-.067-.054-.117-.122-.117m1.7-.265c-.08 0-.137.058-.143.138l-.17 2.976.17 2.568c.006.08.063.138.143.138s.136-.058.143-.138l.193-2.568-.193-2.976c-.007-.08-.063-.138-.143-.138m1.68-.157c-.09 0-.155.065-.16.155l-.143 3.133.143 2.496c.005.09.07.155.16.155s.155-.065.16-.155l.163-2.496-.163-3.133c-.005-.09-.07-.155-.16-.155m1.667-.06c-.1 0-.172.072-.177.17l-.117 3.193.117 2.43c.005.098.077.17.177.17s.172-.072.177-.17l.133-2.43-.133-3.193c-.005-.098-.077-.17-.177-.17m3.358-.75c-.05-.023-.1-.034-.15-.034-.086 0-.17.024-.24.07-.067-1.29-1.134-2.31-2.443-2.31-.357 0-.7.08-1.003.225-.12.053-.15.107-.152.16v8.66c.003.057.048.103.105.107h4.78c.056-.004.1-.05.104-.107l.002-5.82c-.004-.566-.236-1.076-.612-1.45-.07-.07-.146-.133-.228-.19-.014-.008-.028-.015-.04-.024-.024-.016-.047-.033-.074-.045-.017-.01-.033-.02-.05-.03M18.63 9.19c-.224 0-.434.048-.626.132C17.697 7.494 16.18 6.25 14.375 6.25c-.47 0-.92.093-1.33.262-.148.06-.187.12-.19.178v8.548c.004.06.05.108.11.112H18.63c.622 0 1.127-.504 1.127-1.126V10.316c0-.622-.505-1.127-1.127-1.127"/>
        </svg>
      </button>
      <button class="social-btn" title="Spotify" aria-label="Spotify">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
        </svg>
      </button>
      <button class="social-btn" title="Resident Advisor" aria-label="Resident Advisor">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm.387 6.583h2.394c1.86 0 3.086 1.073 3.086 2.753 0 1.197-.618 2.11-1.63 2.572l1.928 3.509h-2.207l-1.68-3.18h-.727v3.18H11.46V6.583h.927zm-.927 1.68v2.412h1.14c.83 0 1.314-.42 1.314-1.206 0-.787-.483-1.206-1.313-1.206H11.46zm-3.48-1.68H6.133v9.834H8v-3.82h1.56l1.568 3.82h2.13l-1.757-4.133C12.405 11.7 12.99 10.76 12.99 9.6c0-1.68-1.226-3.017-3.086-3.017H7.98z"/>
        </svg>
      </button>
    </div>

    <!-- BOOK NOW (desktop only) -->
    <a href={`${base}/contact`} class="btn-book header-book-btn"><span>BOOK NOW</span></a>

    <!-- HAMBURGER (mobile only) -->
    <button class="hamburger-btn" id="hamburger-btn" aria-label="Toggle navigation" aria-expanded="false">
      <span class="h-line"></span>
      <span class="h-line"></span>
      <span class="h-line"></span>
    </button>
  </div>
</header>

<!-- MOBILE NAV OVERLAY (hidden on desktop via CSS) -->
<nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
  <div>
    {navLinks.map((l) => (
      <a
        href={href(l)}
        class={`mobile-nav-link${isActive(l) ? " active" : ""}`}
      >
        {l.toUpperCase()}
      </a>
    ))}
  </div>

  <!-- SOCIAL ICONS IN MOBILE MENU -->
  <div class="mobile-nav-socials">
    <button class="social-btn" title="Instagram" aria-label="Instagram">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <rect x="2" y="2" width="20" height="20" rx="0"/>
        <circle cx="12" cy="12" r="5"/>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
      </svg>
    </button>
    <button class="social-btn" title="SoundCloud" aria-label="SoundCloud">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M1.175 12.225c-.056 0-.094.037-.1.094l-.233 2.154.233 2.105c.006.06.044.094.1.094s.094-.037.1-.094l.255-2.105-.27-2.154c-.006-.057-.045-.094-.1-.094m1.655-.557c-.068 0-.116.05-.122.116l-.2 2.711.2 2.568c.006.067.054.117.122.117s.116-.05.122-.117l.227-2.568-.227-2.71c-.006-.067-.054-.117-.122-.117m3.358-.75c-.05-.023-.1-.034-.15-.034-.086 0-.17.024-.24.07-.067-1.29-1.134-2.31-2.443-2.31-.357 0-.7.08-1.003.225-.12.053-.15.107-.152.16v8.66c.003.057.048.103.105.107h4.78c.056-.004.1-.05.104-.107l.002-5.82c-.004-.566-.236-1.076-.612-1.45a3.56 3.56 0 0 0-.228-.19M18.63 9.19c-.224 0-.434.048-.626.132C17.697 7.494 16.18 6.25 14.375 6.25c-.47 0-.92.093-1.33.262-.148.06-.187.12-.19.178v8.548c.004.06.05.108.11.112H18.63c.622 0 1.127-.504 1.127-1.126V10.316c0-.622-.505-1.127-1.127-1.127"/>
      </svg>
    </button>
    <button class="social-btn" title="Spotify" aria-label="Spotify">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2z"/>
      </svg>
    </button>
  </div>
</nav>

<script>
  const btn = document.getElementById("hamburger-btn")!;
  const body = document.body;

  btn.addEventListener("click", () => {
    const isOpen = body.hasAttribute("data-menu-open");
    body.toggleAttribute("data-menu-open");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close on nav link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      body.removeAttribute("data-menu-open");
      btn.setAttribute("aria-expanded", "false");
    });
  });
</script>

<script>
  const header = document.getElementById("site-header")!;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 80) {
      header.style.background = "#000";
      header.style.borderBottomColor = "#c8102e";
    } else {
      header.style.background = "transparent";
      header.style.borderBottomColor = "transparent";
    }
  }, { passive: true });
</script>
