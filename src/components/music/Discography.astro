---
import { getCollection, getEntry } from "astro:content";
import { t, type Locale } from "../../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const mtEntry = await getEntry("musicText", "music-page");
const uiEntry = await getEntry("ui", "ui");
const mt = mtEntry!.data;
const u = uiEntry!.data;

const releases = (await getCollection("releases")).sort((a, b) =>
  b.data.releaseDate.localeCompare(a.data.releaseDate)
);
---

<section style="background:#000;padding:100px 72px;">
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:16px;display:flex;align-items:center;gap:12px;">
    <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
    {t(mt.discographyHeading, locale)}
  </div>
  <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.18em;margin-bottom:32px;">
    {t(mt.genreTagsLabel, locale)} {t(mt.genreTagsList, locale)}
  </div>

  {releases.length === 0
    ? <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b6b6b;letter-spacing:0.1em;padding:40px 0;">{t(mt.discographyEmptyStateMessage, locale)}</div>
    : <>
        <!-- TABLE HEADER -->
        <div style="display:flex;gap:24px;padding:0 0 12px;border-bottom:1px solid #c8102e;margin-bottom:0;">
          <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.2em;width:48px;flex-shrink:0;">{t(mt.discographyYearHeader, locale)}</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.2em;flex:1;">{t(mt.discographyTitleHeader, locale)}</div>
          <div class="disc-row-meta" style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.2em;width:80px;text-align:center;">{t(mt.discographyFormatHeader, locale)}</div>
          <div class="disc-row-meta" style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.2em;width:120px;">{t(mt.discographyLabelHeader, locale)}</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.2em;width:80px;text-align:right;">{t(mt.discographyStreamsHeader, locale)}</div>
        </div>

        {releases.map((r, i) => (
          <div
            style={`display:flex;gap:24px;align-items:center;padding:20px 0;${i < releases.length - 1 ? 'border-bottom:1px solid #111;' : ''}cursor:pointer;transition:background 0.15s;`}
            onmouseover="this.style.background='#070707'" onmouseout="this.style.background=''"
          >
            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.14em;width:48px;flex-shrink:0;">{r.data.releaseDate.slice(0,4)}</div>
            <div style="flex:1;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#e8e8e8;letter-spacing:0.06em;">{r.data.title}</div>
            </div>
            <div class="disc-row-meta" style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#6b6b6b;letter-spacing:0.1em;width:80px;text-align:center;">{r.data.format}</div>
            <div class="disc-row-meta" style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#6b6b6b;letter-spacing:0.08em;width:120px;">{r.data.label}</div>
            <div style="width:80px;text-align:right;">
              {r.data.spotifyUrl || r.data.appleMusicUrl || r.data.bandcampUrl
                ? <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.1em;">{t(u.cta.streams, locale)}</span>
                : <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#333;letter-spacing:0.1em;">—</span>
              }
            </div>
          </div>
        ))}
      </>
  }
</section>
