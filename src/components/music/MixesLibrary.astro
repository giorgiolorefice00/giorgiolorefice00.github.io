---
import { getCollection } from "astro:content";

const mixes = (await getCollection("mixes")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);

const categoryLabel: Record<string, string> = {
  resident: "resident sets",
  festival: "festival sets",
  radio: "radio shows",
  guest: "guest mixes",
};
---

<section style="background:#0a0a0a;padding:100px 72px;">
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:48px;display:flex;align-items:center;gap:12px;">
    <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
    C — mixes
  </div>

  <!-- FILTER CHIPS -->
  <div id="mix-filters" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:40px;">
    {["all", "resident sets", "festival sets", "radio shows", "guest mixes"].map((f) => (
      <button
        class={`filter-chip${f === "all" ? " active" : ""}`}
        data-filter={f}
        onclick="
          document.querySelectorAll('#mix-filters .filter-chip').forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          const v = this.dataset.filter;
          document.querySelectorAll('.mix-card').forEach(c => {
            c.style.display = (v === 'all' || c.dataset.cat === v) ? '' : 'none';
          });
        "
      >{f}</button>
    ))}
  </div>

  <!-- MIX CARDS -->
  <div class="mix-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    {mixes.map((m) => {
      const cat = categoryLabel[m.data.category] ?? m.data.category;
      const dateStr = m.data.date.slice(0, 7).replace("-", ".");
      return (
        <div class="mix-card" data-cat={cat} style="border:1px solid #1a1a1a;background:#050505;overflow:hidden;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#c8102e'" onmouseout="this.style.borderColor='#1a1a1a'">
          <!-- ARTWORK PLACEHOLDER -->
          <div style="aspect-ratio:1/1;background:linear-gradient(135deg,#0a0002 0%,#050000 50%,#080001 100%);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
            <div class="photo-duotone" style="position:absolute;inset:0;opacity:0.3;">
              <div style="width:100%;height:100%;background:#111;"></div>
            </div>
            <div style="position:relative;text-align:center;padding:16px;">
              <div style="font-family:'Anton',sans-serif;font-size:11px;color:#c8102e;letter-spacing:0.14em;opacity:0.6;">{cat.toUpperCase()}</div>
            </div>
          </div>
          <!-- INFO -->
          <div style="padding:20px;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.18em;margin-bottom:8px;">{cat}</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#e8e8e8;letter-spacing:0.06em;margin-bottom:4px;">{m.data.title}</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.1em;margin-bottom:16px;">{m.data.venue ?? ""} · {dateStr} · {m.data.duration}</div>
            <button class="btn-secondary" style="padding:8px 16px;font-size:9px;width:100%;letter-spacing:0.14em;"><span>▶ LISTEN</span></button>
          </div>
        </div>
      );
    })}
  </div>
</section>
