---
import { getCollection } from "astro:content";

const releases = await getCollection("releases");
const featured = releases.find((r) => r.data.featured);
if (!featured) return;
const { title, subtitle, releaseDate, label, description, tracklist } = featured.data;
const year = releaseDate.slice(0, 7).replace("-", ".").toUpperCase();
---

<section style="background:#000;padding:100px 72px;">
  <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:48px;display:flex;align-items:center;gap:12px;">
    <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
    A — latest release
  </div>

  <div class="release-cols" style="display:flex;gap:64px;align-items:flex-start;">

    <!-- LEFT 40% — artwork placeholder -->
    <div class="release-artwork" style="flex:0 0 40%;aspect-ratio:1/1;position:relative;overflow:hidden;background:#050505;border:1px solid #1a1a1a;display:flex;align-items:center;justify-content:center;">
      <div style="position:absolute;inset:0;background:radial-gradient(circle,transparent 24px,#0a0002 25px);background-size:24px 24px;opacity:0.08;"></div>
      <div style="position:relative;text-align:center;">
        <div style="font-family:'Anton',sans-serif;font-size:clamp(24px,3vw,40px);color:#c8102e;opacity:0.15;letter-spacing:0.06em;line-height:1;">{title.split(" ")[0]}</div>
        <div style="font-family:'Anton',sans-serif;font-size:clamp(24px,3vw,40px);color:#c8102e;opacity:0.15;letter-spacing:0.06em;line-height:1;">{title.split(" ").slice(1).join(" ")}</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.2em;margin-top:16px;opacity:0.5;">[ artwork placeholder ]</div>
      </div>
    </div>

    <!-- RIGHT 60% — metadata -->
    <div style="flex:1;padding:8px 0;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:16px;">[ RELEASE ]</div>
      <div style="font-family:'Anton',sans-serif;font-size:clamp(28px,3.5vw,48px);color:#e8e8e8;letter-spacing:0.02em;line-height:1;margin-bottom:8px;">{title}</div>
      {subtitle && <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#6b6b6b;letter-spacing:0.14em;margin-bottom:6px;">{subtitle}</div>}
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b6b6b;letter-spacing:0.1em;margin-bottom:4px;">{year}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#e8e8e8;letter-spacing:0.08em;font-weight:500;margin-bottom:24px;">{label.toUpperCase()}</div>

      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b6b6b;letter-spacing:0.04em;line-height:1.7;margin-bottom:32px;">{description}</p>

      <!-- TRACKLIST -->
      {tracklist && tracklist.length > 0 && (
        <div style="margin-bottom:32px;border-top:1px solid #1a1a1a;">
          {tracklist.map((t, i) => (
            <div style={`display:flex;justify-content:space-between;align-items:center;padding:12px 0;${i < tracklist.length - 1 ? 'border-bottom:1px solid #111;' : ''}`}>
              <div style="display:flex;align-items:center;gap:16px;">
                <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#c8102e;letter-spacing:0.14em;">{t.number}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#e8e8e8;letter-spacing:0.06em;">{t.title}</span>
              </div>
              <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#6b6b6b;letter-spacing:0.1em;">{t.duration}</span>
            </div>
          ))}
        </div>
      )}

      <!-- STREAMING BUTTONS -->
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        {["▶ SPOTIFY", "▶ APPLE", "▶ BANDCAMP"].map((label) => (
          <button class="btn-secondary" style="padding:8px 14px;font-size:9px;letter-spacing:0.12em;">
            <span>{label}</span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>
