---
import { getCollection, getEntry } from "astro:content";
import { t, type Locale } from "../../lib/i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const pcEntry = await getEntry("homeEvents", "home-events");
const pc = pcEntry!.data;

const rawEvents = await getCollection("events");
const events = rawEvents.sort((a, b) => a.id.localeCompare(b.id));
---

<section data-reveal="slide-up" style="background:#000;padding:120px 72px;border-top:1px solid #c8102e;">

  <!-- SECTION HEADER -->
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:56px;">
    <div>
      <div style="font-family:'Anton',sans-serif;font-size:clamp(48px,5vw,80px);color:#e8e8e8;line-height:1;letter-spacing:0.01em;">{t(pc.eventsHeading, locale)}</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#767676;letter-spacing:0.18em;margin-top:10px;">{t(pc.eventsSubtitle, locale)}</div>
    </div>
    <a href={pc.allTourDates.url || "/events"} class="about-link" style="margin-bottom:6px;">{t(pc.allTourDates, locale)}</a>
  </div>

  <!-- CARDS -->
  <div class="events-row" data-reveal-stagger style="display:flex;gap:16px;">
    {events.map((ev) => {
      const { venue, city, day, month, year, setTime } = ev.data;
      const base = import.meta.env.BASE_URL;
      const contactHref = base.endsWith("/") ? `${base}contact` : `${base}/contact`;
      return (
        <div class="event-card">

          <!-- DATE -->
          <div>
            <div class="event-date-num">{day}</div>
            <div class="event-date-sub">{month} / {year}</div>
          </div>

          <!-- DIVIDER — straight full-width red line -->
          <div style="width:100%;height:1px;background:#c8102e;margin:16px 0;flex-shrink:0;"></div>

          <!-- LOCATION -->
          <div class="event-venue">{venue}</div>
          <div class="event-city">{city}</div>

          <!-- TIME -->
          <div style="margin-top:12px;">
            <div class="event-time">{setTime}</div>
          </div>

          <!-- CTA -->
          <a href={contactHref} class="event-ticket">{t(pc.eventsCardCtaLabel, locale)}</a>

        </div>
      );
    })}
  </div>
</section>
