---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import djPhoto from "../../assets/dj-photo.jpg";

const entry = await getEntry("about", "about");
const { headlineLines, paragraphs, stats } = entry!.data;
---

<section style="background:#000;padding:120px 72px;">
  <div class="about-cols" style="display:flex;gap:80px;align-items:flex-start;">

    <!-- LEFT 60% -->
    <div style="flex:0 0 58%;">
      <!-- EYEBROW -->
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#c8102e;letter-spacing:0.22em;margin-bottom:40px;display:flex;align-items:center;gap:12px;">
        <span style="width:20px;height:1px;background:#c8102e;display:inline-block;"></span>
        [ 001 / about ]
      </div>

      <!-- HEADLINE — index 0: off-white large, index 1: blood-red oversized, index 2: off-white small tracked -->
      <div style="margin-bottom:40px;line-height:1.0;">
        <div style="font-family:'Anton',sans-serif;font-size:clamp(40px,4.5vw,72px);color:#e8e8e8;letter-spacing:0.01em;">{headlineLines[0]}</div>
        <div style="font-family:'Anton',sans-serif;font-size:clamp(56px,6.5vw,104px);color:#c8102e;letter-spacing:0.01em;line-height:0.92;">{headlineLines[1]}</div>
        <div style="font-family:'Anton',sans-serif;font-size:clamp(18px,2vw,28px);color:#e8e8e8;letter-spacing:0.12em;margin-top:12px;">{headlineLines[2]}</div>
      </div>

      <!-- BODY -->
      <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:48px;">
        {paragraphs.map((p) => (
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#6b6b6b;line-height:1.8;letter-spacing:0.04em;">{p}</p>
        ))}
      </div>

      <!-- LINK -->
      <a href="#" class="about-link">
        read the full story
        <span class="arrow">→</span>
      </a>
    </div>

    <!-- RIGHT 40% -->
    <div class="about-right" style="flex:1 1 0;display:flex;flex-direction:column;gap:0;">
      <!-- PORTRAIT -->
      <div style="position:relative;width:100%;aspect-ratio:1/1;overflow:hidden;">
        <div class="photo-duotone" style="position:absolute;inset:0;">
          <Image src={djPhoto} width={600} height={600} alt="Giorgio Lorefice portrait" style="width:100%;height:100%;object-fit:cover;object-position:30% 20%;" loading="lazy" />
        </div>
        <div style="position:absolute;top:0;left:0;width:1px;height:100%;background:#c8102e;z-index:5;"></div>
      </div>

      <!-- STATS -->
      <div class="about-stats" style="display:flex;flex-direction:column;gap:0;border-left:1px solid #1a1a1a;">
        {stats.map((s, i) => (
          <div class="stat-block" style={`padding:24px 28px;${i < stats.length - 1 ? "border-bottom:1px solid #111;" : ""}`}>
            <div class="stat-num">{s.num}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
